# Copier ce fichier en ".env" et renseigner les valeurs.
# Le fichier ".env" est gitignore — ne jamais commiter de secrets.
# Mettre à jour ce fichier et src/env.js lors de tout ajout de variable.

# --- Connexion PostgreSQL ---
# Développement local : pointer vers PostgreSQL local ou NAS via Tailscale
DATABASE_URL="postgresql://postgres:password@localhost:5432/pacal"

# Production NAS (docker-compose) : remplacer localhost par le nom du conteneur PostgreSQL
# DATABASE_URL="postgresql://postgres:password@postgresql:5432/pacal"

NODE_ENV="development"
